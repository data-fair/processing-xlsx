{
  "type": "object",
  "layout": "tabs",
  "required": [
    "datasetMode"
  ],
  "allOf": [
    {
      "title": "Dataset mode",
      "x-i18n-title": { "fr": "Liste de jeux de données", "en": "Datasets" },
      "default": {
        "datasetMode": "list"
      },
      "oneOf": [
        {
          "title": "List sheets",
          "x-i18n-title": { "fr": "Lister les différentes feuilles", "en": "List the available sheets" },
          "properties": {
            "datasetMode": {
              "type": "string",
              "const": "list",
              "title": "Action"
            }
          }
        },
        {
          "title": "Create datasets",
          "x-i18n-title": { "fr": "Créer des jeux de données", "en": "Create datasets" },
          "required": [
            "dataset"
          ],
          "properties": {
            "datasetMode": {
              "type": "string",
              "const": "create",
              "title": "Action"
            },
            "dataset": {
              "type": "object",
              "required": [
                "prefix"
              ],
              "properties": {
                "prefix": {
                  "type": "string",
                  "title": "Datasets prefix",
                  "x-i18n-title": { "fr": "Préfixe des noms des jeux de données", "en": "Datasets name prefix" },
                  "description": "Dataset titles are built from this prefix and the matching sheet name.",
                  "x-i18n-description": { "fr": "Les titres des jeux de données sont construits avec ce préfixe et le nom de la feuille correspondante.", "en": "Dataset titles are built from this prefix and the matching sheet name." }
                }
              }
            }
          }
        },
        {
          "title": "Update datasets",
          "x-i18n-title": { "fr": "Mettre à jour des jeux de données", "en": "Update datasets" },
          "properties": {
            "datasetMode": {
              "type": "string",
              "const": "update",
              "title": "Action"
            },
            "datasets": {
              "type": "array",
              "title": "Datasets to update",
              "x-i18n-title": { "fr": "Jeux à mettre à jour", "en": "Datasets to update" },
              "layout": {
                "listEditMode": "inline"
              },
              "items": {
                "type": "object",
                "layout": [
                  {
                    "children": [
                      "dataset"
                    ],
                    "cols": 5
                  },
                  {
                    "children": [
                      "idSheet"
                    ],
                    "cols": 3
                  },
                  {
                    "children": [
                      "forceUpdate"
                    ],
                    "cols": 3
                  }
                ],
                "required": [
                  "dataset",
                  "idSheet"
                ],
                "properties": {
                  "dataset": {
                    "type": "object",
                    "title": "Existing dataset",
                    "x-i18n-title": { "fr": "Jeu de données existant", "en": "Existing dataset" },
                    "properties": {
                      "id": {
                        "type": "string",
                        "title": "Identifier",
                        "x-i18n-title": { "fr": "Identifiant", "en": "Identifier" }
                      },
                      "href": {
                        "type": "string",
                        "title": "URL"
                      },
                      "title": {
                        "type": "string",
                        "title": "Title",
                        "x-i18n-title": { "fr": "Titre", "en": "Title" }
                      }
                    },
                    "layout": {
                      "getItems": {
                        "url": "${context.dataFairUrl}/api/v1/datasets?q={q}&select=id,title&${context.ownerFilter}&$file=true",
                        "itemsResults": "data.results",
                        "itemTitle": "item.title",
                        "itemKey": "item.id"
                      }
                    }
                  },
                  "idSheet": {
                    "type": "integer",
                    "title": "Sheet number",
                    "x-i18n-title": { "fr": "Numéro de la feuille", "en": "Sheet number" },
                    "minimum": 1
                  },
                  "forceUpdate": {
                    "type": "boolean",
                    "title": "Force schema update",
                    "x-i18n-title": { "fr": "Forcer la mise à jour du schéma", "en": "Force schema update" }
                  }
                }
              }
            }
          }
        }
      ]
    },
    {
      "title": "Parameters",
      "x-i18n-title": { "fr": "Paramètres", "en": "Parameters" },
      "required": [
        "url"
      ],
      "properties": {
        "url": {
          "title": "Source URL",
          "x-i18n-title": { "fr": "URL source", "en": "Source URL" },
          "type": "string",
          "description": "Supported protocols are HTTP and HTTPS; supported formats are .zip and .xlsx.",
          "x-i18n-description": { "fr": "Les protocoles supportés sont HTTP et HTTPS, les formats supportés sont .zip et .xlsx.", "en": "Supported protocols are HTTP and HTTPS; supported formats are .zip and .xlsx." }
        },
        "addAllSheets": {
          "type": "boolean",
          "title": "Add all the sheets",
          "x-i18n-title": { "fr": "Ajouter toutes les feuilles", "en": "Add all the sheets" },
          "layout": {
            "if": "parent.parent.data.datasetMode === 'create'"
          }
        },
        "idsSheets": {
          "type": "array",
          "title": "Sheets to extract",
          "x-i18n-title": { "fr": "Feuilles à extraire", "en": "Sheets to extract" },
          "items": {
            "type": "integer",
            "minimum": 1
          },
          "description": "The numbers correspond to the indexes of the sheets to extract.",
          "x-i18n-description": { "fr": "Les nombres à indiquer correspondent aux numéros des feuilles à extraire.", "en": "The numbers correspond to the indexes of the sheets to extract." },
          "layout": {
            "if": "parent.parent.data.datasetMode === 'create' && parent.data.addAllSheets === false"
          }
        }
      }
    }
  ]
}
